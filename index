<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>工程项目管理系统 - Notion 嵌入版</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;700&display=swap" rel="stylesheet">
    <style>
        body { 
            font-family: 'Noto Sans SC', sans-serif; 
            background: #ffffff;
            /* Notion 嵌入时移除默认边距 */
            margin: 0;
            padding: 0;
            overflow-x: hidden;
        }
        /* 针对 Notion 嵌入优化的高度 */
        .notion-embed-container {
            min-height: 600px;
            max-height: 800px;
            overflow-y: auto;
        }
        .compact-table td, .compact-table th {
            padding: 8px 12px;
            font-size: 13px;
        }
        .status-select {
            appearance: none;
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3e%3cpath stroke='%236b7280' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M6 8l4 4 4-4'/%3e%3c/svg%3e");
            background-position: right 4px center;
            background-repeat: no-repeat;
            background-size: 16px;
            padding-right: 24px;
        }
    </style>
<base target="_blank">
</head>
<body class="bg-white">
    <div class="notion-embed-container w-full">
        <!-- 顶部工具栏 -->
        <div class="sticky top-0 z-50 bg-white border-b border-gray-200 px-4 py-3 flex justify-between items-center shadow-sm">
            <div class="flex items-center space-x-2">
                <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center text-white font-bold text-sm">
                    工
                </div>
                <div>
                    <h1 class="text-base font-bold text-gray-900 leading-tight">工程管理系统</h1>
                    <p class="text-[10px] text-gray-500">Project Management</p>
                </div>
            </div>
            <div class="flex items-center space-x-2">
                <button onclick="toggleView('list')" id="btn-list" class="px-3 py-1.5 text-xs font-medium rounded-md bg-blue-50 text-blue-700 border border-blue-200">
                    列表视图
                </button>
                <button onclick="toggleView('stats')" id="btn-stats" class="px-3 py-1.5 text-xs font-medium rounded-md bg-gray-50 text-gray-600 border border-gray-200 hover:bg-gray-100">
                    统计视图
                </button>
                <button onclick="openModal()" class="px-3 py-1.5 bg-blue-600 hover:bg-blue-700 text-white text-xs font-medium rounded-md shadow-sm flex items-center space-x-1">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                    <span>新建</span>
                </button>
            </div>
        </div>

        <!-- 统计概览（可折叠） -->
        <div id="stats-panel" class="hidden bg-gray-50 border-b border-gray-200 px-4 py-3">
            <div class="grid grid-cols-4 gap-3">
                <div class="bg-white rounded-lg p-3 border border-gray-200 shadow-sm">
                    <p class="text-[10px] text-gray-500 uppercase">项目总数</p>
                    <p class="text-lg font-bold text-gray-900" id="stat-count">0</p>
                </div>
                <div class="bg-white rounded-lg p-3 border border-gray-200 shadow-sm">
                    <p class="text-[10px] text-gray-500 uppercase">工程总款</p>
                    <p class="text-lg font-bold text-emerald-600" id="stat-amount">¥0</p>
                </div>
                <div class="bg-white rounded-lg p-3 border border-gray-200 shadow-sm">
                    <p class="text-[10px] text-gray-500 uppercase">总支出</p>
                    <p class="text-lg font-bold text-rose-600" id="stat-expense">¥0</p>
                </div>
                <div class="bg-white rounded-lg p-3 border border-gray-200 shadow-sm">
                    <p class="text-[10px] text-gray-500 uppercase">结余</p>
                    <p class="text-lg font-bold text-blue-600" id="stat-balance">¥0</p>
                </div>
            </div>
        </div>

        <!-- 筛选栏 -->
        <div class="bg-white px-4 py-2 border-b border-gray-100 flex items-center space-x-2 overflow-x-auto">
            <span class="text-xs text-gray-500 whitespace-nowrap">筛选:</span>
            <button onclick="filterProjects('all')" class="filter-btn px-2.5 py-1 rounded-full text-xs font-medium bg-gray-800 text-white" data-filter="all">全部</button>
            <button onclick="filterProjects('备案')" class="filter-btn px-2.5 py-1 rounded-full text-xs font-medium bg-amber-50 text-amber-700 border border-amber-200" data-filter="备案">备案</button>
            <button onclick="filterProjects('验槽')" class="filter-btn px-2.5 py-1 rounded-full text-xs font-medium bg-blue-50 text-blue-700 border border-blue-200" data-filter="验槽">验槽</button>
            <button onclick="filterProjects('验收')" class="filter-btn px-2.5 py-1 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700 border border-emerald-200" data-filter="验收">验收</button>
            <button onclick="filterProjects('completed')" class="filter-btn px-2.5 py-1 rounded-full text-xs font-medium bg-purple-50 text-purple-700 border border-purple-200" data-filter="completed">已完工</button>
            <div class="flex-1"></div>
            <input type="text" id="search-input" placeholder="搜索项目..." oninput="renderTable()" 
                class="text-xs border border-gray-300 rounded-md px-2 py-1 w-32 focus:outline-none focus:ring-2 focus:ring-blue-500">
        </div>

        <!-- 项目表格 -->
        <div class="overflow-x-auto">
            <table class="w-full text-left compact-table">
                <thead class="bg-gray-50 text-xs font-semibold text-gray-600 uppercase tracking-wider sticky top-0">
                    <tr>
                        <th class="border-b border-gray-200 w-12">序号</th>
                        <th class="border-b border-gray-200 w-24">日期</th>
                        <th class="border-b border-gray-200 min-w-[180px]">项目名称</th>
                        <th class="border-b border-gray-200 text-right w-24">工程款</th>
                        <th class="border-b border-gray-200 text-right w-24">支出</th>
                        <th class="border-b border-gray-200 text-right w-24">结余</th>
                        <th class="border-b border-gray-200 text-center w-20">进展</th>
                        <th class="border-b border-gray-200 min-w-[100px]">备注</th>
                        <th class="border-b border-gray-200 text-center w-16">操作</th>
                    </tr>
                </thead>
                <tbody id="project-list" class="divide-y divide-gray-100 text-xs text-gray-700">
                    <!-- 动态生成 -->
                </tbody>
            </table>
        </div>

        <!-- 空状态 -->
        <div id="empty-state" class="hidden py-8 text-center">
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-gray-100 mb-2">
                <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path></svg>
            </div>
            <p class="text-gray-500 text-xs">暂无项目数据</p>
        </div>
    </div>

    <!-- 新建/编辑模态框 -->
    <div id="modal" class="hidden fixed inset-0 z-50 bg-black bg-opacity-50 flex items-center justify-center p-4">
        <div class="bg-white rounded-xl shadow-2xl w-full max-w-md max-h-[90vh] overflow-y-auto">
            <div class="px-4 py-3 border-b border-gray-200 flex justify-between items-center sticky top-0 bg-white">
                <h3 class="font-bold text-gray-900" id="modal-title">新建项目</h3>
                <button onclick="closeModal()" class="text-gray-400 hover:text-gray-600">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <form id="project-form" class="p-4 space-y-3" onsubmit="saveProject(event)">
                <input type="hidden" id="edit-id">
                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <label class="block text-xs font-medium text-gray-700 mb-1">日期 <span class="text-red-500">*</span></label>
                        <input type="date" id="input-date" required class="w-full text-sm border border-gray-300 rounded-md px-2 py-1.5 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-gray-700 mb-1">项目名称 <span class="text-red-500">*</span></label>
                        <input type="text" id="input-name" required placeholder="输入项目名称" class="w-full text-sm border border-gray-300 rounded-md px-2 py-1.5 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <label class="block text-xs font-medium text-gray-700 mb-1">工程款 (元)</label>
                        <input type="number" id="input-amount" step="0.01" placeholder="0.00" class="w-full text-sm border border-gray-300 rounded-md px-2 py-1.5 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-gray-700 mb-1">支出 (元)</label>
                        <input type="number" id="input-expense" step="0.01" value="0" class="w-full text-sm border border-gray-300 rounded-md px-2 py-1.5 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
                    </div>
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-700 mb-2">当前进展</label>
                    <div class="grid grid-cols-3 gap-2">
                        <label class="cursor-pointer">
                            <input type="radio" name="status" value="备案" class="hidden peer" checked>
                            <div class="text-center py-2 rounded-md border-2 border-gray-200 text-xs peer-checked:border-amber-500 peer-checked:bg-amber-50 transition-all">
                                备案
                            </div>
                        </label>
                        <label class="cursor-pointer">
                            <input type="radio" name="status" value="验槽" class="hidden peer">
                            <div class="text-center py-2 rounded-md border-2 border-gray-200 text-xs peer-checked:border-blue-500 peer-checked:bg-blue-50 transition-all">
                                验槽
                            </div>
                        </label>
                        <label class="cursor-pointer">
                            <input type="radio" name="status" value="验收" class="hidden peer">
                            <div class="text-center py-2 rounded-md border-2 border-gray-200 text-xs peer-checked:border-emerald-500 peer-checked:bg-emerald-50 transition-all">
                                验收
                            </div>
                        </label>
                    </div>
                </div>
                <div class="flex items-center">
                    <input type="checkbox" id="input-completed" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500">
                    <label for="input-completed" class="ml-2 text-xs text-gray-700">标记为已完工</label>
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-700 mb-1">备注</label>
                    <textarea id="input-note" rows="2" placeholder="添加备注信息..." class="w-full text-sm border border-gray-300 rounded-md px-2 py-1.5 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none resize-none"></textarea>
                </div>
                <div class="flex space-x-2 pt-2">
                    <button type="button" onclick="closeModal()" class="flex-1 px-4 py-2 border border-gray-300 rounded-md text-xs font-medium text-gray-700 hover:bg-gray-50">取消</button>
                    <button type="submit" class="flex-1 px-4 py-2 bg-blue-600 text-white rounded-md text-xs font-medium hover:bg-blue-700 shadow-sm">保存</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        // 初始数据
        let projects = JSON.parse(localStorage.getItem('notion-projects')) || [
            { id: 1, date: '2026-03-01', name: '阳光花园一期', amount: 850000, expense: 320000, status: '备案', completed: false, note: '规划审批中' },
            { id: 2, date: '2026-02-28', name: '市政道路A段改造', amount: 1200000, expense: 450000, status: '验槽', completed: false, note: '地质勘查完成' },
            { id: 3, date: '2026-02-25', name: '商业综合体主体', amount: 3500000, expense: 1800000, status: '验收', completed: false, note: '预计下周验收' },
            { id: 4, date: '2026-02-20', name: '学校教学楼', amount: 2800000, expense: 2800000, status: '验收', completed: true, note: '已交付' }
        ];

        let currentFilter = 'all';
        let currentView = 'list';

        // 初始化
        document.addEventListener('DOMContentLoaded', () => {
            document.getElementById('input-date').valueAsDate = new Date();
            renderTable();
            updateStats();
        });

        // 保存到 localStorage（仅当前设备有效）
        function saveToStorage() {
            localStorage.setItem('notion-projects', JSON.stringify(projects));
        }

        // 切换视图
        function toggleView(view) {
            currentView = view;
            document.getElementById('btn-list').className = view === 'list' 
                ? 'px-3 py-1.5 text-xs font-medium rounded-md bg-blue-50 text-blue-700 border border-blue-200'
                : 'px-3 py-1.5 text-xs font-medium rounded-md bg-gray-50 text-gray-600 border border-gray-200 hover:bg-gray-100';
            document.getElementById('btn-stats').className = view === 'stats'
                ? 'px-3 py-1.5 text-xs font-medium rounded-md bg-blue-50 text-blue-700 border border-blue-200'
                : 'px-3 py-1.5 text-xs font-medium rounded-md bg-gray-50 text-gray-600 border border-gray-200 hover:bg-gray-100';
            
            document.getElementById('stats-panel').classList.toggle('hidden', view !== 'stats');
        }

        // 渲染表格
        function renderTable() {
            const tbody = document.getElementById('project-list');
            const emptyState = document.getElementById('empty-state');
            tbody.innerHTML = '';

            let filtered = projects;
            if (currentFilter !== 'all') {
                if (currentFilter === 'completed') {
                    filtered = projects.filter(p => p.completed);
                } else {
                    filtered = projects.filter(p => p.status === currentFilter && !p.completed);
                }
            }

            const searchTerm = document.getElementById('search-input').value.toLowerCase();
            if (searchTerm) {
                filtered = filtered.filter(p => p.name.toLowerCase().includes(searchTerm));
            }

            filtered.sort((a, b) => {
                if (a.completed !== b.completed) return a.completed ? 1 : -1;
                return new Date(b.date) - new Date(a.date);
            });

            if (filtered.length === 0) {
                emptyState.classList.remove('hidden');
                return;
            }
            emptyState.classList.add('hidden');

            filtered.forEach((p, index) => {
                const balance = p.amount - p.expense;
                const tr = document.createElement('tr');
                tr.className = `hover:bg-gray-50 transition-colors ${p.completed ? 'bg-gray-50 opacity-60' : ''}`;
                
                const statusColors = {
                    '备案': 'bg-amber-100 text-amber-800 border-amber-200',
                    '验槽': 'bg-blue-100 text-blue-800 border-blue-200',
                    '验收': 'bg-emerald-100 text-emerald-800 border-emerald-200'
                };

                tr.innerHTML = `
                    <td class="font-medium text-gray-900">${index + 1}</td>
                    <td class="text-gray-600">${p.date}</td>
                    <td>
                        <div class="font-medium ${p.completed ? 'line-through text-gray-500' : 'text-gray-900'}">${p.name}</div>
                        ${p.completed ? '<span class="text-[10px] text-purple-600">已完工</span>' : ''}
                    </td>
                    <td class="text-right font-medium text-emerald-600">¥${p.amount.toLocaleString()}</td>
                    <td class="text-right font-medium text-rose-600">¥${p.expense.toLocaleString()}</td>
                    <td class="text-right font-bold ${balance >= 0 ? 'text-blue-600' : 'text-rose-600'}">¥${balance.toLocaleString()}</td>
                    <td class="text-center">
                        ${!p.completed ? `
                            <select onchange="updateStatus(${p.id}, this.value)" class="status-select text-xs font-medium px-2 py-1 rounded-full border ${statusColors[p.status]} outline-none cursor-pointer">
                                <option value="备案" ${p.status === '备案' ? 'selected' : ''}>备案</option>
                                <option value="验槽" ${p.status === '验槽' ? 'selected' : ''}>验槽</option>
                                <option value="验收" ${p.status === '验收' ? 'selected' : ''}>验收</option>
                            </select>
                        ` : '<span class="text-xs px-2 py-1 rounded-full bg-purple-100 text-purple-700 border border-purple-200">已完工</span>'}
                    </td>
                    <td class="text-gray-600 truncate max-w-[100px]" title="${p.note}">${p.note || '-'}</td>
                    <td class="text-center">
                        <div class="flex justify-center space-x-1">
                            <button onclick="editProject(${p.id})" class="p-1 text-gray-400 hover:text-blue-600 hover:bg-blue-50 rounded">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                            </button>
                            <button onclick="deleteProject(${p.id})" class="p-1 text-gray-400 hover:text-rose-600 hover:bg-rose-50 rounded">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                            </button>
                        </div>
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        // 更新统计
        function updateStats() {
            const totalAmount = projects.reduce((sum, p) => sum + p.amount, 0);
            const totalExpense = projects.reduce((sum, p) => sum + p.expense, 0);
            
            document.getElementById('stat-count').textContent = projects.length;
            document.getElementById('stat-amount').textContent = `¥${(totalAmount/10000).toFixed(1)}万`;
            document.getElementById('stat-expense').textContent = `¥${(totalExpense/10000).toFixed(1)}万`;
            document.getElementById('stat-balance').textContent = `¥${((totalAmount-totalExpense)/10000).toFixed(1)}万`;
        }

        // 筛选
        function filterProjects(filter) {
            currentFilter = filter;
            document.querySelectorAll('.filter-btn').forEach(btn => {
                if (btn.dataset.filter === filter) {
                    btn.classList.add('ring-2', 'ring-offset-1', 'ring-gray-400');
                } else {
                    btn.classList.remove('ring-2', 'ring-offset-1', 'ring-gray-400');
                }
            });
            renderTable();
        }

        // 模态框操作
        function openModal() {
            document.getElementById('modal').classList.remove('hidden');
            document.getElementById('modal-title').textContent = '新建项目';
            document.getElementById('project-form').reset();
            document.getElementById('edit-id').value = '';
            document.getElementById('input-date').valueAsDate = new Date();
        }

        function closeModal() {
            document.getElementById('modal').classList.add('hidden');
        }

        // 保存项目
        function saveProject(e) {
            e.preventDefault();
            const id = document.getElementById('edit-id').value;
            const project = {
                id: id ? parseInt(id) : Date.now(),
                date: document.getElementById('input-date').value,
                name: document.getElementById('input-name').value,
                amount: parseFloat(document.getElementById('input-amount').value) || 0,
                expense: parseFloat(document.getElementById('input-expense').value) || 0,
                status: document.querySelector('input[name="status"]:checked').value,
                completed: document.getElementById('input-completed').checked,
                note: document.getElementById('input-note').value
            };

            if (id) {
                const index = projects.findIndex(p => p.id == id);
                if (index !== -1) projects[index] = project;
            } else {
                projects.push(project);
            }

            saveToStorage();
            closeModal();
            renderTable();
            updateStats();
        }

        // 编辑
        function editProject(id) {
            const p = projects.find(p => p.id === id);
            if (!p) return;

            document.getElementById('edit-id').value = p.id;
            document.getElementById('input-date').value = p.date;
            document.getElementById('input-name').value = p.name;
            document.getElementById('input-amount').value = p.amount;
            document.getElementById('input-expense').value = p.expense;
            document.getElementById('input-note').value = p.note || '';
            document.getElementById('input-completed').checked = p.completed;
            
            document.querySelectorAll('input[name="status"]').forEach(r => {
                r.checked = r.value === p.status;
            });

            document.getElementById('modal-title').textContent = '编辑项目';
            document.getElementById('modal').classList.remove('hidden');
        }

        // 删除
        function deleteProject(id) {
            if (confirm('确定删除该项目？')) {
                projects = projects.filter(p => p.id !== id);
                saveToStorage();
                renderTable();
                updateStats();
            }
        }

        // 更新状态
        function updateStatus(id, status) {
            const p = projects.find(p => p.id === id);
            if (p) {
                p.status = status;
                saveToStorage();
                renderTable();
            }
        }

        // 点击模态框外部关闭
        document.getElementById('modal').addEventListener('click', (e) => {
            if (e.target === document.getElementById('modal')) closeModal();
        });
    </script>
</body>
</html>
